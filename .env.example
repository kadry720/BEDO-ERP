COMPOSE_PROJECT_NAME=bedo_erp

MARIADB_ROOT_PASSWORD=change-this-root-password
MARIADB_DATABASE=frappe
MARIADB_USER=frappe
MARIADB_PASSWORD=change-this-db-password

FRAPPE_BRANCH=version-15
FRAPPE_BENCH_PATH=/workspace/frappe-bench
BEDO_APP_PATH=/workspace/BEDO-ERP/apps/bedo_erp
FRAPPE_SITE_NAME=bedo.localhost
FRAPPE_SITE_ALIASES=localhost 127.0.0.1
FRAPPE_ADMIN_PASSWORD=change-this-site-admin-password

REDIS_CACHE_URL=redis://redis-cache:6379
REDIS_QUEUE_URL=redis://redis-queue:6379
REDIS_SOCKETIO_URL=redis://redis-socketio:6379

LDAP_SERVER_URL=ldap://ldap.example.local
LDAP_BASE_DN=dc=example,dc=local
LDAP_BIND_DN=cn=frappe-reader,ou=service,dc=example,dc=local
LDAP_BIND_PASSWORD=change-this-ldap-bind-password
LDAP_USER_SEARCH_BASE=ou=users,dc=example,dc=local
LDAP_GROUP_SEARCH_BASE=ou=groups,dc=example,dc=local
