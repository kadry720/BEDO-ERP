COMPOSE_PROJECT_NAME=bedo_platform

MARIADB_ROOT_PASSWORD=replace-me-root-password
MARIADB_DATABASE=frappe
MARIADB_USER=frappe
MARIADB_PASSWORD=replace-me-db-password

FRAPPE_BRANCH=version-15
FRAPPE_BENCH_PATH=/workspace/frappe-bench
BEDO_APP_NAME=bedo_platform
BEDO_APP_PATH=/workspace/BEDO-ERP/apps/bedo_platform
FRAPPE_SITE_NAME=bedo.localhost
FRAPPE_ADMIN_PASSWORD=replace-me-site-admin-password

REDIS_CACHE_URL=redis://redis-cache:6379
REDIS_QUEUE_URL=redis://redis-queue:6379
REDIS_SOCKETIO_URL=redis://redis-socketio:6379

LDAP_URI=ldaps://ldap.example.local
LDAP_BASE_DN=dc=example,dc=local
LDAP_BIND_DN=cn=frappe-reader,ou=service,dc=example,dc=local
LDAP_BIND_PASSWORD=replace-me-ldap-bind-password
LDAP_USER_SEARCH_FILTER=(uid={username})
LDAP_USE_TLS=true
LDAP_CERT_REQUIRED=true
LDAP_TIMEOUT=5

BEDO_LDAP_ADAPTER=mock
BEDO_MOCK_LDAP_PASSWORD_GM=replace-me-local-dev-password
BEDO_MOCK_LDAP_PASSWORD_ARD_MANAGER=replace-me-local-dev-password
BEDO_SEED_GM_PASSWORD=replace-me-local-seed-password
BEDO_SEED_ARD_MANAGER_PASSWORD=replace-me-local-seed-password
