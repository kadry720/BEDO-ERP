#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PYTHON_CMD=()

select_python() {
  if [ -n "${PYTHON:-}" ] && "${PYTHON}" --version >/dev/null 2>&1; then
    PYTHON_CMD=("${PYTHON}")
    return
  fi
  if command -v python3 >/dev/null 2>&1 && python3 --version >/dev/null 2>&1; then
    PYTHON_CMD=(python3)
    return
  fi
  if command -v python >/dev/null 2>&1 && python --version >/dev/null 2>&1; then
    PYTHON_CMD=(python)
    return
  fi
  if command -v py >/dev/null 2>&1 && py -3 --version >/dev/null 2>&1; then
    PYTHON_CMD=(py -3)
    return
  fi
  echo "Python 3 is required. Set PYTHON=/path/to/python and rerun ./scripts/bedo." >&2
  exit 1
}

cd "${ROOT_DIR}"
select_python

usage() {
  cat <<'EOF'
Usage: ./scripts/bedo <command>

Commands:
  up             Generate .env if needed, build images, start BEDO locally
  down           Stop BEDO containers
  logs           Follow Compose logs
  doctor         Validate local config and run smoke checks when services are up
  credentials    Print local bootstrap credentials from .env
  reset-local    Stop containers and remove local Docker volumes
EOF
}

command="${1:-}"
case "${command}" in
  up)
    "${PYTHON_CMD[@]}" scripts/generate_env.py
    docker compose up -d --build
    echo
    echo "BEDO is starting at http://localhost:3000"
    "${PYTHON_CMD[@]}" scripts/generate_env.py --print-credentials
    ;;
  down)
    docker compose down
    ;;
  logs)
    docker compose logs -f "${@:2}"
    ;;
  doctor)
    "${PYTHON_CMD[@]}" scripts/generate_env.py
    docker compose config >/dev/null
    if docker compose ps --format json 2>/dev/null | grep -q '"Service"'; then
      "${PYTHON_CMD[@]}" scripts/smoke.py
    else
      echo "Compose configuration is valid. Services are not running, so smoke checks were skipped."
    fi
    ;;
  credentials)
    "${PYTHON_CMD[@]}" scripts/generate_env.py --print-credentials
    ;;
  reset-local)
    docker compose down -v --remove-orphans
    echo "Local BEDO containers and volumes were removed. .env was left unchanged."
    ;;
  ""|-h|--help|help)
    usage
    ;;
  *)
    usage >&2
    exit 2
    ;;
esac
