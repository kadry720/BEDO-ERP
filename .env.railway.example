BEDO_ENV=production
FRAPPE_BRANCH=version-15
FRAPPE_BENCH_PATH=/workspace/frappe-bench
BEDO_APP_NAME=bedo_platform
BEDO_APP_PATH=/workspace/BEDO-ERP/apps/bedo_platform
FRAPPE_SITE_NAME=bedo.example.com
FRAPPE_ADMIN_PASSWORD=replace-with-strong-frappe-admin-password

MARIADB_HOST=your-mariadb-host.railway.internal
MARIADB_PORT=3306
MARIADB_ROOT_PASSWORD=replace-with-railway-mariadb-root-password
MARIADB_PASSWORD=replace-with-frappe-site-db-password

REDIS_CACHE_URL=redis://default:password@your-redis-host.railway.internal:6379
REDIS_QUEUE_URL=redis://default:password@your-redis-host.railway.internal:6379
REDIS_SOCKETIO_URL=redis://default:password@your-redis-host.railway.internal:6379

BEDO_WEB_PUBLIC_URL=https://your-vercel-domain.vercel.app
BEDO_WEB_SERVICE_SECRET=replace-with-same-value-as-vercel
BEDO_FORCE_SEED_PASSWORD_RESET=0
BEDO_SEED_DEFAULT_PASSWORD=replace-with-one-time-bootstrap-password
BEDO_SRS_DEADLINE_MODE=working_days
